# .env.example — copy to .env and fill in values
OPENAI_API_KEY=sk-...              # Required: OpenAI API key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_LLM_MODEL=gpt-4o

POSTGRES_URL=postgresql://user:password@localhost:5432/financial_rag
REDIS_URL=redis://localhost:6379/0

SEC_EDGAR_USER_AGENT=YourName YourEmail@example.com

LOG_LEVEL=INFO
ENVIRONMENT=development

# src/financial_rag/config.py
from pydantic_settings import BaseSettings

class Settings(BaseSettings):
    openai_api_key: str
    openai_embedding_model: str = 'text-embedding-3-large'
    openai_llm_model: str = 'gpt-4o'
    postgres_url: str
    redis_url: str
    log_level: str = 'INFO'
    environment: str = 'development'

    class Config:
        env_file = '.env'

settings = Settings()   # Fails immediately if required vars are missing
git commit -am "feat: add environment configuration with .env.example"
